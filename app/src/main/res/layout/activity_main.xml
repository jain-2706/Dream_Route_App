<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F5F9"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:layout_marginTop="50dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"

        android:paddingTop="20dp"
        android:paddingBottom="40dp">

        <!-- Gradient Top Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@drawable/gradient_top_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stream Finder"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explore all options and find your best-fit stream"
                    android:textSize="16sp"
                    android:textColor="#E0E0E0"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Instruction Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Discover Your Best-Fit Stream"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#212121"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/subtext"
                    android:textSize="16sp"
                    android:textColor="#616161"
                    android:layout_marginTop="12dp"
                    tools:text="Answer a few quick questions to find out whether Maths, Science, Arts, or Commerce suits you best"/>

                <!-- Stream Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/maths"
                        style="@style/StreamButtonStyle"
                        android:text="Maths"
                        android:drawableTop="@drawable/number_svg"
                        android:layout_marginEnd="16dp"/>

                    <Button
                        android:id="@+id/science"
                        style="@style/StreamButtonStyle"
                        android:text="Science"
                        android:drawableTop="@drawable/art_svg"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/arts"
                        style="@style/StreamButtonStyle"
                        android:text="Arts"
                        android:drawableTop="@drawable/brush_svg"
                        android:layout_marginEnd="16dp"/>

                    <Button
                        android:id="@+id/commerce"
                        style="@style/StreamButtonStyle"
                        android:text="Commerce"
                        android:drawableTop="@drawable/commerce_svg"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
