<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Actual_Quiz_UI"
    android:orientation="vertical"

    android:gravity="center">
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="15dp"
        >
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="32dp"
            app:cardCornerRadius="12dp"

            >
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="30dp"
                android:paddingBottom="20dp"
                android:paddingStart="10dp"
                android:background="#3949AB"
                >
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stream Finder"
                        android:textSize="20sp"
                        android:textColor="#fff"
                        android:textStyle="bold"

                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Explore All Options"
                        android:textSize="20sp"
                        android:textColor="#fff"
                        android:textStyle="bold"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/domain"
                    android:textColor="#fff"
                    android:textSize="17sp"
                    android:background="@drawable/domain_background"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="10dp"
                    android:textStyle="bold"
                    android:gravity="center"
                    />
            </LinearLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                >


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:text="Question 1 of 10"
                    android:id="@+id/question_no"
                    android:layout_marginStart="20dp">


                </TextView>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="10%"
                    android:layout_marginStart="280dp"
                    android:textSize="18sp"
                    android:id="@+id/progress"
                    >

                </TextView>
            </FrameLayout>

            <SeekBar
                android:layout_width="250dp"
                android:layout_height="20dp"
                android:progress="1"
                android:max="10"
               android:fitsSystemWindows="true"
                android:scrollbarStyle="outsideOverlay"
                android:layout_marginTop="10dp"

                android:layout_gravity="center_horizontal"
                android:id="@+id/seek_b"

                />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/recycler_view"
                    android:background="@drawable/background_of_recycler_view"
                    android:layout_gravity="center_horizontal"/>
                </LinearLayout>

</LinearLayout>


        </androidx.cardview.widget.CardView>
    </LinearLayout>



</LinearLayout>